export default function AgentOS() {
  const [st, dispatch] = useReducer(red, init);
  const [task, setTask] = useState("");
  const [view, setView] = useState("pipeline"); // pipeline | detail | logs | metrics | settings
  const [selectedAgent, setSelectedAgent] = useState(null);
  const cancelRef = useRef(false);

  const openAgent = useCallback((id) => { setSelectedAgent(id); setView("detail"); }, []);
  const closeAgent = useCallback(() => { setSelectedAgent(null); setView("pipeline"); }, []);
  const cancelPipeline = useCallback(() => { cancelRef.current = true; }, []);

  const runPipeline = useCallback(async () => {
    if (!task.trim() || !st.keys[st.provider]) return;
    cancelRef.current = false;
    dispatch({ t: "RST" });
    dispatch({ t: "ST", v: "running" });
    // Mark all agents as queued before starting
    AGENTS_FULL.forEach(a => dispatch({ t: "AG", id: a.id, d: { status: "queued" } }));

    let prevOutput = "";
    for (const agent of AGENTS_FULL) {
      if (cancelRef.current) {
        dispatch({ t: "ST", v: "idle" });
        dispatch({ t: "LOG", from: agent.id, lt: "warn", text: "Pipeline cancelled by user." });
        break;
      }
      dispatch({ t: "AG", id: agent.id, d: { status: "running", error: null } });
      dispatch({ t: "LOG", from: agent.id, lt: "info", text: "Starting..." });
      try {
        const input = `Task: ${task}\n\nPrevious agent output:\n${prevOutput.slice(0, 600) || "(first in pipeline)"}\n\nYour role: ${agent.role}. Execute.`;
        const r = await callLLM(st, dispatch, agent.id, agent.sys, input, agent.maxTok);
        dispatch({ t: "AG", id: agent.id, d: { status: "done", tokens: r.tok, elapsed: r.ms, cost: r.cost, output: r.text } });

        const next = AGENTS_FULL[AGENTS_FULL.indexOf(agent) + 1];
        if (next) dispatch({ t: "BUS", from: agent.id, to: next.id, text: r.text.slice(0, 80) + "..." });
        prevOutput = r.text;
      } catch (e) {
        dispatch({ t: "AG", id: agent.id, d: { status: "error", error: e.message } });
        dispatch({ t: "LOG", from: agent.id, lt: "error", text: `Failed: ${e.message}` });
        dispatch({ t: "ST", v: "error" });
        return;
      }
    }
    if (!cancelRef.current) dispatch({ t: "ST", v: "done" });
  }, [st, task]);

  const nav = [
    { id: "pipeline", label: "Pipeline", icon: "\u25C8" },
    { id: "logs", label: "Logs", icon: "\u25CE" },
    { id: "metrics", label: "Stats", icon: "\u25C9" },
    { id: "settings", label: "Settings", icon: "\u2699" },
  ];

  return (
    <div style={{ minHeight: "100vh", background: T.bg, color: T.tx, fontFamily: T.fn, paddingBottom: 64, WebkitFontSmoothing: "antialiased" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap');
        @keyframes blink { 50% { opacity: 0 } }
        @keyframes pulse { 0%,100% { opacity: 1 } 50% { opacity: 0.4 } }
        @keyframes scan { 0% { transform: translateX(-100%) } 100% { transform: translateX(400%) } }
        @keyframes slideUp { from { transform: translateY(8px); opacity: 0 } to { transform: translateY(0); opacity: 1 } }
        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        ::-webkit-scrollbar { width: 3px } ::-webkit-scrollbar-track { background: transparent } ::-webkit-scrollbar-thumb { background: ${T.bd}; border-radius: 2px }
        body { margin: 0; overflow-x: hidden; background: ${T.bg} }
        input, textarea, button { font-family: ${T.fn} }
      `}</style>

      {/* ══ HEADER ══ */}
      <div style={{
        position: "sticky", top: 0, zIndex: 100,
        padding: "12px 14px",
        background: `${T.bg}F0`,
        backdropFilter: "blur(20px)", WebkitBackdropFilter: "blur(20px)",
        borderBottom: `1px solid ${T.bd}`,
      }}>
        <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
          <div style={{
            width: 8, height: 8, borderRadius: "50%",
            background: st.status === "running" ? T.ac : st.status === "error" ? T.dn : T.txD,
            boxShadow: st.status === "running" ? `0 0 8px ${T.ac}` : "none",
            transition: "all 0.3s",
          }} />
          <span style={{ fontSize: 15, fontWeight: 800, letterSpacing: 3, color: T.ac, fontFamily: T.fd }}>AGENT OS</span>
          <span style={{
            fontSize: 8, color: PROVIDERS[st.provider]?.color,
            background: `${PROVIDERS[st.provider]?.color}12`,
            padding: "2px 7px", borderRadius: 10, fontWeight: 600,
            border: `1px solid ${PROVIDERS[st.provider]?.color}22`,
          }}>
            {PROVIDERS[st.provider]?.name} / {PROVIDERS[st.provider]?.models.find(m => m.id === st.model)?.label || st.model.split("/").pop()}
          </span>
          <div style={{ flex: 1 }} />
          <Badge status={st.status} />
        </div>
        {/* Running indicator */}
        {st.status === "running" && (
          <div style={{ position: "absolute", bottom: 0, left: 0, right: 0, height: 2, overflow: "hidden" }}>
            <div style={{ width: "30%", height: "100%", background: `linear-gradient(90deg,transparent,${T.ac},transparent)`, animation: "scan 2s linear infinite" }} />
          </div>
        )}
      </div>

      {/* ══ CONTENT ══ */}
      <div style={{ padding: "12px 14px 80px" }}>
        {/* Task input — pipeline view only */}
        {view === "pipeline" && (
          <div style={{ marginBottom: 12 }}>
            <textarea
              value={task} onChange={e => setTask(e.target.value)}
              placeholder="Describe what to build... (e.g. 'e-commerce platform with auth, cart, payments')"
              rows={2} disabled={st.status === "running"}
              aria-label="Task description"
              style={{
                width: "100%", background: T.s, border: `1px solid ${T.bd}`, borderRadius: T.r,
                color: T.tx, padding: 12, fontSize: 13, resize: "none", outline: "none",
                lineHeight: 1.5, transition: "border-color 0.2s", fontFamily: T.fn,
              }}
              onFocus={e => e.target.style.borderColor = T.ac}
              onBlur={e => e.target.style.borderColor = T.bd}
            />
            <div style={{ display: "flex", gap: 8, marginTop: 8 }}>
              <button
                onClick={runPipeline}
                disabled={st.status === "running" || !task.trim() || !st.keys[st.provider]}
                aria-label={st.status === "running" ? "Pipeline running" : "Run pipeline"}
                style={{
                  flex: 1, padding: "12px 0",
                  background: (st.status === "running" || !st.keys[st.provider] || !task.trim()) ? T.s2 : `linear-gradient(135deg, ${T.ac}, #059669)`,
                  color: (st.status === "running" || !st.keys[st.provider] || !task.trim()) ? T.txD : T.bg,
                  border: "none", borderRadius: T.rs, fontSize: 12, fontWeight: 700,
                  cursor: (st.status === "running" || !task.trim() || !st.keys[st.provider]) ? "not-allowed" : "pointer",
                  letterSpacing: 2, transition: "all 0.2s", fontFamily: T.fn,
                }}
              >
                {st.status === "running" ? "RUNNING..." : !st.keys[st.provider] ? "ADD API KEY \u2192 SETTINGS" : !task.trim() ? "ENTER A TASK" : "RUN PIPELINE"}
              </button>
              {st.status === "running" && (
                <button
                  onClick={cancelPipeline}
                  aria-label="Cancel pipeline"
                  style={{
                    padding: "12px 16px", background: `${T.dn}15`, color: T.dn,
                    border: `1px solid ${T.dn}33`, borderRadius: T.rs, fontSize: 11,
                    fontWeight: 700, cursor: "pointer", fontFamily: T.fn, letterSpacing: 1,
                    transition: "all 0.2s",
                  }}
                >
                  CANCEL
                </button>
              )}
            </div>
          </div>
        )}

        {/* Metrics strip — pipeline view only */}
        {view === "pipeline" && (
          <>
            <MetricStrip metrics={st.metrics} />
            <TokenBar perAgent={st.metrics.perAgent} total={st.metrics.totalTok} />
          </>
        )}

        {/* Pipeline view */}
        {view === "pipeline" && (
          <div style={{ display: "flex", flexDirection: "column", gap: 8, marginTop: 12, animation: "slideUp .2s ease-out" }}>
            {AGENTS_FULL.map(a => (
              <AgentCard key={a.id} agent={a} state={st.agents[a.id]} stream={st.streams[a.id]} onTap={() => openAgent(a.id)} />
            ))}
          </div>
        )}

        {/* Agent detail */}
        {view === "detail" && selectedAgent && AGENTS[selectedAgent] && (
          <AgentDetail
            agent={AGENTS[selectedAgent]} state={st.agents[selectedAgent]}
            logs={st.logs} stream={st.streams[selectedAgent]}
            st={st} dispatch={dispatch} onBack={closeAgent}
          />
        )}

        {/* Logs */}
        {view === "logs" && (
          <div style={{ marginTop: 12, animation: "slideUp .2s ease-out" }}>
            <div style={{ background: T.s, borderRadius: T.r, border: `1px solid ${T.bd}`, overflow: "hidden" }}>
              <div style={{ padding: "10px 14px", borderBottom: `1px solid ${T.bd}`, display: "flex", alignItems: "center" }}>
                <span style={{ fontSize: 11, fontWeight: 700, color: T.txM, letterSpacing: 1 }}>GLOBAL LOG</span>
                <span style={{ fontSize: 9, color: T.txD, marginLeft: "auto" }}>{st.logs.length} entries</span>
              </div>
              <LogList logs={st.logs} maxHeight={400} />
            </div>
            {st.bus.length > 0 && (
              <div style={{ marginTop: 10, background: T.s, borderRadius: T.r, border: `1px solid ${T.bd}`, overflow: "hidden" }}>
                <div style={{ padding: "10px 14px", borderBottom: `1px solid ${T.bd}` }}>
                  <span style={{ fontSize: 11, fontWeight: 700, color: T.txM, letterSpacing: 1 }}>AGENT BUS</span>
                </div>
                <div style={{ maxHeight: 200, overflowY: "auto" }}>
                  {st.bus.map(m => (
                    <div key={m.id} style={{ padding: "4px 10px", fontSize: 10, borderBottom: `1px solid ${T.bd}` }}>
                      <span style={{ color: AGENTS[m.from]?.color }}>{AGENTS[m.from]?.name}</span>
                      <span style={{ color: T.txD }}> {"\u2192"} </span>
                      <span style={{ color: AGENTS[m.to]?.color }}>{AGENTS[m.to]?.name}</span>
                      <span style={{ color: T.txD, marginLeft: 6, fontSize: 8 }}>{m.time}</span>
                      <div style={{ color: T.txM, paddingLeft: 8, fontSize: 9, marginTop: 1 }}>{m.text.slice(0, 80)}</div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {/* Metrics */}
        {view === "metrics" && (
          <div style={{ marginTop: 12, animation: "slideUp .2s ease-out" }}>
            <MetricStrip metrics={st.metrics} />
            <TokenBar perAgent={st.metrics.perAgent} total={st.metrics.totalTok} />
            <div style={{ height: 10 }} />
            <div style={{ background: T.s, borderRadius: T.r, border: `1px solid ${T.bd}`, padding: 14 }}>
              <div style={{ fontSize: 11, fontWeight: 700, color: T.txM, letterSpacing: 1, marginBottom: 10 }}>AGENT BREAKDOWN</div>
              {AGENTS_FULL.map(a => {
                const s = st.agents[a.id];
                const tok = st.metrics.perAgent[a.id] || 0;
                const pct = st.metrics.totalTok ? ((tok / st.metrics.totalTok) * 100).toFixed(1) : "0";
                return (
                  <div key={a.id} onClick={() => openAgent(a.id)} style={{
                    display: "flex", alignItems: "center", gap: 8, padding: "8px 0",
                    borderBottom: `1px solid ${T.bd}`, cursor: "pointer",
                  }}>
                    <span style={{ fontSize: 14, color: a.color, width: 20 }}>{a.icon}</span>
                    <span style={{ fontSize: 11, color: T.tx, flex: 1 }}>{a.name}</span>
                    <Badge status={s.status} color={a.color} />
                    <span style={{ fontSize: 9, color: T.txM, width: 50, textAlign: "right" }}>{tok} tok</span>
                    <span style={{ fontSize: 9, color: a.color, fontWeight: 700, width: 36, textAlign: "right" }}>{pct}%</span>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {/* Settings */}
        {view === "settings" && <SettingsView st={st} dispatch={dispatch} />}
      </div>

      {/* ══ BOTTOM NAV ══ */}
      <div style={{
        position: "fixed", bottom: 0, left: 0, right: 0, zIndex: 100,
        display: "flex", background: `${T.bg}F5`,
        backdropFilter: "blur(20px)", WebkitBackdropFilter: "blur(20px)",
        borderTop: `1px solid ${T.bd}`,
        padding: "6px 0",
        paddingBottom: "max(6px, env(safe-area-inset-bottom))",
      }}>
        {nav.map(n => {
          const active = (view === n.id) || (view === "detail" && n.id === "pipeline");
          return (
            <button
              key={n.id}
              aria-label={n.label}
              aria-current={active ? "page" : undefined}
              onClick={() => { setView(n.id); setSelectedAgent(null); }}
              style={{
                flex: 1, display: "flex", flexDirection: "column", alignItems: "center", gap: 2,
                background: "none", border: "none", cursor: "pointer",
                color: active ? T.ac : T.txD, padding: "4px 0",
                transition: "color 0.15s", fontFamily: T.fn,
              }}
            >
              <span style={{ fontSize: 16, transition: "transform 0.15s", transform: active ? "scale(1.1)" : "scale(1)" }}>{n.icon}</span>
              <span style={{ fontSize: 8, fontWeight: active ? 700 : 400, letterSpacing: 0.5 }}>{n.label}</span>
              {active && <div style={{ width: 16, height: 2, borderRadius: 1, background: T.ac, marginTop: 1 }} />}
            </button>
          );
        })}
      </div>
    </div>
  );
}
