};

function red(st, a) {
  switch (a.t) {
    case "KEY": return { ...st, keys: { ...st.keys, [a.p]: a.v } };
    case "PROV": return { ...st, provider: a.v, model: PROVIDERS[a.v].models[0].id };
    case "MOD": return { ...st, model: a.v };
    case "ST": return { ...st, status: a.v };
    case "AG": { const ag = { ...st.agents }; ag[a.id] = { ...ag[a.id], ...a.d }; return { ...st, agents: ag }; }
    case "LOG": return { ...st, logs: [...st.logs, { id: gid(), time: ts(), from: a.from, type: a.lt, text: a.text }] };
    case "BUS": return { ...st, bus: [...st.bus, { id: gid(), time: ts(), from: a.from, to: a.to, text: a.text }] };
    case "STR": { const s = { ...st.streams }; s[a.id] = a.text; return { ...st, streams: s }; }
    case "MET": {
      const p = { ...st.metrics.perAgent }; p[a.id] = (p[a.id] || 0) + a.tok;
      return { ...st, metrics: { totalTok: st.metrics.totalTok + a.tok, totalMs: st.metrics.totalMs + a.ms, totalCost: st.metrics.totalCost + a.cost, perAgent: p } };
    }
    case "RST": return { ...init, keys: st.keys, provider: st.provider, model: st.model };
    default: return st;
  }
}

// ══ API CALL ══
async function callLLM(st, dispatch, agentId, sysPrompt, userMsg, maxTok) {
  const prov = PROVIDERS[st.provider];
  const key = st.keys[st.provider];
  if (!key) throw new Error(`No API key for ${prov.name}`);

  dispatch({ t: "LOG", from: agentId, lt: "info", text: `${prov.name} / ${st.model}` });
  const t0 = Date.now();
  const req = prov.build(key, st.model, sysPrompt, [{ role: "user", content: userMsg }], maxTok || 1024);

  const res = await fetch(req.url, { method: "POST", headers: req.h, body: JSON.stringify(req.b) });
  if (!res.ok) { const e = await res.text(); throw new Error(`${res.status}: ${e.slice(0, 100)}`); }

  const data = await res.json();
  const parsed = prov.parse(data);
  const ms = Date.now() - t0;
  const cost = (parsed.tok / 1000) * prov.cost;

  // Stream simulation
  const chars = parsed.text.split("");
  let buf = "";
  const ch = Math.max(2, Math.floor(chars.length / 25));
  for (let i = 0; i < chars.length; i += ch) {
    buf += chars.slice(i, i + ch).join("");
    dispatch({ t: "STR", id: agentId, text: buf });
    await sleep(18);
  }
  dispatch({ t: "STR", id: agentId, text: parsed.text });
  dispatch({ t: "MET", id: agentId, tok: parsed.tok, ms, cost });
  dispatch({ t: "LOG", from: agentId, lt: "success", text: `${ms}ms | ${parsed.tok} tok | $${cost.toFixed(5)}` });

  return { text: parsed.text, tok: parsed.tok, ms, cost };
}

