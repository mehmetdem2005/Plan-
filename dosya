              ))}
            </div>
          )}
          {tab === "tools" && (
            <div style={{ padding: 12 }}>
              {agent.tools.map(t => (
                <div key={t} style={{ padding: "4px 0", fontSize: 10, color: T.txM, display: "flex", alignItems: "center", gap: 6 }}>
                  <span style={{ color: T.wn, fontWeight: 700 }}>#</span>
                  <span style={{ color: T.tx }}>{t}</span>
                </div>
              ))}
            </div>
          )}
          {tab === "config" && (
            <div style={{ padding: 12, fontSize: 10, lineHeight: 2, color: T.txM }}>
              <div>Temperature: <b style={{ color: T.tx }}>{agent.temp}</b></div>
              <div>Max tokens: <b style={{ color: T.tx }}>{agent.maxTok}</b></div>
              <div>Output format: <b style={{ color: T.tx }}>{agent.format}</b></div>
              <div>Inputs from: <b style={{ color: T.tx }}>{agent.inputFrom.length ? agent.inputFrom.join(", ") : "none (root)"}</b></div>
              <div>Outputs to: <b style={{ color: T.tx }}>{agent.outputTo.join(", ") || "none"}</b></div>
