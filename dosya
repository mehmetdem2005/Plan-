          )}
        </div>

        {/* Error */}
        {state.error && (
          <div style={{ padding: "8px 16px", background: `${T.dn}08`, borderTop: `1px solid ${T.dn}22`, fontSize: 10, color: T.dn }}>{state.error}</div>
