      {children}
    </button>
  );
}

function Badge({ status, color }) {
  const c = { idle: T.txD, queued: "#6366F1", running: color || T.ac, done: T.ac, error: T.dn, paused: T.wn };
  const l = { idle: "IDLE", queued: "QUEUE", running: "RUNNING", done: "DONE", error: "ERROR", paused: "PAUSED" };
  const s = c[status] || T.txD;
  return (
    <span style={{
      padding: "2px 6px", fontSize: 7, fontWeight: 700, letterSpacing: 1,
      color: s, background: `${s}15`, border: `1px solid ${s}33`, borderRadius: 4,
      display: "inline-flex", alignItems: "center", gap: 3,
    }}>
      {status === "running" && <span style={{ width: 4, height: 4, borderRadius: "50%", background: s, animation: "pulse 1.5s infinite" }} />}
      {l[status] || "--"}
    </span>
  );
}

function LogList({ logs, maxHeight = 250, limit = 200, filter = null }) {
  const ref = useRef(null);
  const filtered = filter ? logs.filter(l => l.from === filter) : logs;
  const display = filtered.slice(-limit);
  useEffect(() => { ref.current && (ref.current.scrollTop = ref.current.scrollHeight); }, [display.length]);
  const col = { info: T.txM, success: T.ac, error: T.dn, warn: T.wn, data: "#A78BFA" };
  return (
    <div ref={ref} style={{ maxHeight: maxHeight, overflowY: "auto", fontSize: 10, lineHeight: 1.7 }}>
      {display.length === 0 && <div style={{ padding: 16, color: T.txD, textAlign: "center", fontSize: 11 }}>No logs yet</div>}
      {display.map(e => (
        <div key={e.id} style={{ padding: "2px 10px", borderLeft: `2px solid ${col[e.type] || T.txD}22` }}>
          <span style={{ color: T.txD, fontSize: 8, marginRight: 4 }}>{e.time}</span>
          {e.from && !filter && <span style={{ color: AGENTS[e.from]?.color || T.inf, marginRight: 4 }}>[{(AGENTS[e.from]?.name || e.from).slice(0, 8)}]</span>}
          <span style={{ color: col[e.type] || T.txM }}>{e.text}</span>
        </div>
      ))}
    </div>
  );
}

function StreamBox({ text, color, streaming = false }) {
  const ref = useRef(null);
  useEffect(() => { ref.current && (ref.current.scrollTop = ref.current.scrollHeight); }, [text]);
  if (!text) return (
    <div style={{ padding: 16, color: T.txD, fontSize: 11, textAlign: "center", fontFamily: T.fn }}>
      Awaiting output...
    </div>
  );
  const lines = text.split("\n");
  return (
    <pre ref={ref} style={{
      margin: 0, padding: 10, fontSize: 10, lineHeight: 1.6,
      color: color || T.tx, whiteSpace: "pre-wrap", wordBreak: "break-all",
      maxHeight: 260, overflowY: "auto", background: `${T.bg}99`, fontFamily: T.fn,
    }}>
      {lines.map((l, i) => (
        <div key={`line-${i}`} style={{ opacity: i < lines.length - 1 ? 0.75 : 1 }}>
          <span style={{ color: T.txD, marginRight: 6, fontSize: 8, userSelect: "none" }}>{String(i + 1).padStart(3)}</span>
          {l}
        </div>
      ))}
      {streaming && (
        <span style={{ display: "inline-block", width: 6, height: 13, background: color || T.ac, animation: "blink 1s step-end infinite", verticalAlign: "middle" }} />
      )}
    </pre>
  );
}

function MetricStrip({ metrics }) {
  const items = [
    { l: "TOKENS", v: metrics.totalTok, c: T.ac },
    { l: "TIME", v: `${(metrics.totalMs / 1000).toFixed(1)}s`, c: T.inf },
    { l: "COST", v: `$${metrics.totalCost.toFixed(4)}`, c: T.wn },
  ];
  return (
    <div style={{ display: "flex", gap: 4 }}>
      {items.map(m => (
        <div key={m.l} style={{ flex: 1, background: T.s, borderRadius: T.rs, padding: "6px 8px", border: `1px solid ${T.bd}` }}>
          <div style={{ fontSize: 7, color: T.txM, letterSpacing: 1, fontWeight: 600 }}>{m.l}</div>
          <div style={{ fontSize: 14, fontWeight: 700, color: m.c, fontFamily: T.fn }}>{m.v}</div>
        </div>
      ))}
    </div>
  );
}

function TokenBar({ perAgent, total }) {
  if (!total) return null;
  return (
    <div style={{ display: "flex", height: 4, borderRadius: 2, overflow: "hidden", background: T.bd, marginTop: 6 }}>
      {AGENTS_FULL.map(a => {
        const t = perAgent[a.id] || 0;
        const p = (t / total) * 100;
        if (!p) return null;
        return <div key={a.id} style={{ width: `${p}%`, background: a.color, transition: "width 0.5s" }} title={`${a.name}: ${t}`} />;
      })}
    </div>
  );
}

