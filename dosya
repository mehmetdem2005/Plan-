              marginTop: 10, padding: "8px 0", width: "100%",
              background: (state.status === "running" || !st.keys[st.provider]) ? T.s2 : `linear-gradient(135deg, ${agent.color}, ${agent.color}88)`,
              color: (state.status === "running" || !st.keys[st.provider]) ? T.txD : T.bg,
              border: "none", borderRadius: T.rs, fontSize: 11, fontWeight: 700,
