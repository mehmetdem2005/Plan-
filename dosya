// ══ Agent Detail View ══
function AgentDetail({ agent, state, logs, stream, st, dispatch, onBack }) {
  const [tab, setTab] = useState("logs");
  const agentLogs = logs.filter(l => l.from === agent.id);

  const runSingle = async () => {
    if (!st.keys[st.provider]) return;
    dispatch({ t: "AG", id: agent.id, d: { status: "running", error: null, tokens: 0, elapsed: 0, cost: 0, output: "" } });
    dispatch({ t: "LOG", from: agent.id, lt: "info", text: `Running ${agent.name} standalone...` });
    try {
      const r = await callLLM(st, dispatch, agent.id, agent.sys, `Execute your role as ${agent.role}. Provide a comprehensive structured response. Be concise and use the defined output format.`, agent.maxTok);
      dispatch({ t: "AG", id: agent.id, d: { status: "done", tokens: r.tok, elapsed: r.ms, cost: r.cost, output: r.text } });
      dispatch({ t: "LOG", from: agent.id, lt: "success", text: `Completed in ${r.ms}ms | ${r.tok} tokens` });
    } catch (e) {
      dispatch({ t: "AG", id: agent.id, d: { status: "error", error: e.message } });
      dispatch({ t: "LOG", from: agent.id, lt: "error", text: `Error: ${e.message}` });
