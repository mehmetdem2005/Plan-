      }}>
        {"\u2190"} Back
      </button>

      <div style={{ background: T.s, borderRadius: T.r, border: `1px solid ${agent.color}22`, overflow: "hidden" }}>
        {/* Agent header */}
        <div style={{ padding: "14px 16px", background: `${agent.color}06`, borderBottom: `1px solid ${agent.color}12` }}>
          <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
            <div style={{
              width: 44, height: 44, borderRadius: "50%",
              border: `2px solid ${agent.color}66`,
              display: "flex", alignItems: "center", justifyContent: "center",
              fontSize: 20, color: agent.color, background: `${agent.color}08`,
            }}>
              {agent.icon}
            </div>
            <div style={{ flex: 1 }}>
              <div style={{ fontSize: 16, fontWeight: 800, color: T.tx, fontFamily: T.fd }}>{agent.name}</div>
              <div style={{ fontSize: 10, color: T.txM, marginTop: 2 }}>{agent.role}</div>
              <div style={{ fontSize: 9, color: T.txD, marginTop: 1 }}>Layer {agent.layer} / {agent.layerName} / {agent.category}</div>
            </div>
            <Badge status={state.status} color={agent.color} />
          </div>
          <p style={{ fontSize: 10, color: T.txM, margin: "10px 0 0", lineHeight: 1.6 }}>{agent.desc}</p>
          {/* Run button */}
          <button
